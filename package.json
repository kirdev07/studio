{
  "name": "kirdev-studio-site",
  "version": "1.0.0",
  "private": true,
  "description": "Static website for KirDev Studio.",
  "scripts": {
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "lint": "eslint \"static/js/**/*.js\" \"scripts/**/*.mjs\"",
    "test": "node scripts/validate-site.mjs",
    "check": "npm run lint && npm test"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "eslint": "9.30.1",
    "globals": "16.3.0",
    "prettier": "3.6.2"
  }
}

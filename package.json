{
  "name": "kirdev-studio-site",
  "version": "1.0.0",
  "private": true,
  "description": "Static website for KirDev Studio.",
  "scripts": {
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "lint": "eslint \"static/js/**/*.js\"",
    "check": "npm run format:check && npm run lint"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "eslint": "9.30.1",
    "globals": "16.3.0",
    "prettier": "3.6.2"
  }
}
